{
  "private": true,
  "scripts": {
    "build": "nuxt build --dotenv .env.prod",
    "build-poc": "nuxt build --dotenv .env.poc",
    "build-dev": "nuxt build --dotenv .env.localhost",
    "build-devserver": "nuxt build --dotenv .env.dev",
    "build-local": "nuxt build --dotenv .env.localhost",
    "build-stage": "nuxt build --dotenv .env.stage",
    "nuxt-build-devserver": "npx nuxi generate --dotenv .env.dev",
    "dev": "nuxt dev",
    "dev-local": "nuxt dev --dotenv .env.localhost",
    "dev-devserver": "nuxt dev --dotenv .env.dev",
    "dev-prod": "nuxt dev --dotenv .env.prod",
    "dev-stage": "nuxt dev --dotenv .env.stage",
    "generate": "nuxt generate",
    "generate-local": "nuxt generate --dotenv .env.localhost",
    "generate-dev": "nuxt generate --dotenv .env.dev",
    "preview": "npm run build && wrangler dev",
    "preview-local": "nuxt generate --dotenv .env.localhost && nuxt preview",
    "preview-dev": "nuxt generate --dotenv .env.dev && nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint \"**/*.{ts,tsx,vue,js}\" --fix",
    "lint-eslint": "eslint --ignore-path .gitignore **/*{ts,tsx,vue,js,json} --fix",
    "lint-prettier": "prettier --write \"**/*.(ts|tsx|vue|js|json)\"",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@element-plus/nuxt": "^1.0.7",
    "@nuxt/eslint-config": "^0.2.0",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@types/crypto-js": "^4.1.1",
    "@types/sockjs-client": "^1.5.3",
    "@types/ws": "^8.5.8",
    "dayjs-nuxt": "^2.1.11",
