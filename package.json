    "eslint": "^8.49.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt": "^4.0.3",
    "nuxt-quasar-ui": "2.1.13",
    "sass": "^1.66.1",
    "sass-loader": "^13.3.2",
    "wrangler": "^4.76.0"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.1.0",
    "@pinia/nuxt": "^0.11.2",
    "@quasar/extras": "1.16.4",
